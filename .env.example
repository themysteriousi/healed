# ── Frontend (.env in /Users/omchauhan/healed/) ─────────────────────────────

# Get a free API key at https://dashboard.pimlico.io
VITE_PIMLICO_API_KEY=your_pimlico_api_key_here

# Paste these after running: cd contracts && npx hardhat run scripts/deploy.cjs --network baseSepolia
VITE_MUSD_ADDRESS=0x0000000000000000000000000000000000000000
VITE_BADGE_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional: override Base Sepolia RPC (free public endpoint works fine)
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# ── Contracts (.env in /Users/omchauhan/healed/contracts/) ──────────────────

# Your deployer wallet private key (NEVER commit this!)
DEPLOYER_PRIVATE_KEY=0xabc...

# Optional: BaseScan API key for contract verification
# Get one free at https://basescan.org/register
BASESCAN_API_KEY=

# Base Sepolia RPC
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
